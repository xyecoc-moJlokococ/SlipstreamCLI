<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/slipnet_card_soft" />
            <stroke
                android:width="1dp"
                android:color="@color/slipnet_accent" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/slipnet_input" />
            <stroke
                android:width="1dp"
                android:color="@color/slipnet_stroke" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
